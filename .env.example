# Copy this file to .env.local and fill in your values

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nwpremiumdesign.com

# Resend API key — get one free at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email address where contact form submissions are delivered
CONTACT_EMAIL_TO=alex@nwpremiumdesign.com

# Google Sheet webhook URL (Apps Script web app) for logging form submissions
GOOGLE_SHEET_WEBHOOK_URL=
